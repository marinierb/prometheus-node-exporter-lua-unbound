{
    "version": "2.0.0",
    "options": {
        "env": {
            "RSYNC_CMD": "rsync -avz --progress",
            "PROMETHEUS_SRC":    "${workspaceFolder}/prometheus-node-exporter-lua-unbound/files/usr/lib/lua/prometheus-collectors/unbound.lua",
            "PROMETHEUS_DST":    "root@192.168.1.1:/usr/lib/lua/prometheus-collectors/unbound.lua",
            "PROMETHEUS_PST":    "ssh root@192.168.1.1 service prometheus-node-exporter-lua restart",
            "PROMETHEUS_PST2":   "brave http://router:9100/metrics",
            "PACKAGES_SCRIPT":   "cp ${workspaceFolder}/prometheus-node-exporter-lua-unbound/files/usr/lib/lua/prometheus-collectors/unbound.lua /home/bruno/OpenWrt/packages/utils/prometheus-node-exporter-lua/files/usr/lib/lua/prometheus-collectors/unbound.lua",
            "PACKAGES_MAKEFILE": "cp ${workspaceFolder}/prometheus-node-exporter-lua-unbound/Makefile.formal                                     /home/bruno/OpenWrt/packages/utils/prometheus-node-exporter-lua/Makefile",
            "PACKAGES_CD":       "cd /home/bruno/OpenWrt/openwrt",
            "PACKAGES_MAKE":     "make -j16 package/prometheus-node-exporter-lua/{clean,compile} V=s",
            "PACKAGES_CHECK":    "ls -ltr bin/packages/aarch64_cortex-a53/packages",
            "PACKAGE_COPY":      "rsync -av /home/bruno/OpenWrt/openwrt/bin/packages/aarch64_cortex-a53/packages/prometheus-node-exporter-lua-unbound-* root@router:/root/",
            "PACKAGE_INSTALL":   "ssh root@router apk add --allow-untrusted /root/prometheus-node-exporter-lua-unbound-*.apk"
        }
    },
    "tasks": [
        {
            "label": "$(arrow-right) Deploy to router",
            "type": "shell",
            "command": "$RSYNC_CMD $PROMETHEUS_SRC $PROMETHEUS_DST && $PROMETHEUS_PST && $PROMETHEUS_PST2",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "statusbar": {
                    "color" : "#226dd6"
                }
            }
        },
        // {
        //     "label": "$(arrow-right) Create and Push Tag",
        //     "type": "shell",
        //     "command": "TAG=$(grep -E '^(PKG_VERSION|PKG_RELEASE)' Makefile | grep -v 'PKG_RELEASE:=1$' | cut -d'=' -f2 | tr -d ' ' | tr '\n' '-') && TAG=v${TAG%-} && git tag $TAG && git push origin $TAG",
        //     "problemMatcher": [],
        //     "presentation": {
        //         "echo": true,
        //         "reveal": "always",
        //         "focus": false,
        //         "panel": "shared"
        //     },
        //     "options": {
        //         "statusbar": {
        //             "color" : "#226dd6"
        //         }
        //     }
        // },
        {
            "label": "$(arrow-right) Copy to packages",
            "type": "shell",
            "command": "$PACKAGES_SCRIPT && $PACKAGES_MAKEFILE",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "statusbar": {
                    "color" : "#226dd6"
                }
            }
        },
        {
            "label": "$(arrow-right) Make",
            "type": "shell",
            "command": "$PACKAGES_CD && $PACKAGES_MAKE && $PACKAGES_CHECK",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "statusbar": {
                    "color" : "#226dd6"
                }
            }
        },
        {
            "label": "$(arrow-right) Install",
            "type": "shell",
            "command": "$PACKAGE_COPY && $PACKAGE_INSTALL && $PROMETHEUS_PST2",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "statusbar": {
                    "color" : "#226dd6"
                }
            }
        }
    ]
}
