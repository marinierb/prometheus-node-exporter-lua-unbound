{
    "version": "2.0.0",
    "options": {
        "env": {
            "SCRIPT":         "${workspaceFolder}/unbound.lua",
            "ROUTER_SCRIPT":  "root@192.168.1.1:/usr/lib/lua/prometheus-collectors/unbound.lua",
            "ROUTER_RESTART": "ssh root@192.168.1.1 service prometheus-node-exporter-lua restart",
            "ROUTER_TEST":    "brave http://router:9100/metrics",
            "MAKEFILE":       "${workspaceFolder}/Makefile",
            "MAKE_SCRIPT":    "/home/bruno/Repos/packages/utils/prometheus-node-exporter-lua/files/usr/lib/lua/prometheus-collectors/unbound.lua",
            "MAKE_MAKEFILE":  "/home/bruno/Repos/packages/utils/prometheus-node-exporter-lua/Makefile",
            "MAKE_DIR":       "/home/bruno/Repos/openwrt",
            "MAKE_CMD":       "make -j16 package/prometheus-node-exporter-lua/{clean,compile} V=sc",
            "MAKE_CHECK":     "ls -ltr bin/packages/aarch64_cortex-a53/packages",
            "MADE_COPY":      "rsync -av /home/bruno/OpenWrt/openwrt/bin/packages/aarch64_cortex-a53/packages/prometheus-node-exporter-lua-unbound-* root@router:/mnt/sda1/",
            "MADE_INSTALL":   "ssh root@router apk add --allow-untrusted /mnt/sda1/prometheus-node-exporter-lua-unbound-*.apk"
        }
    },
    "tasks": [
        {
            "label": "$(arrow-right) Copy to router",
            "type": "shell",
            "command": "rsync -av $SCRIPT $ROUTER_SCRIPT && $ROUTER_RESTART && $ROUTER_TEST",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "statusbar": {
                    "color" : "#226dd6"
                }
            }
        },
        {
            "label": "$(arrow-right) Make",
            "type": "shell",
            "command": "cp $SCRIPT $MAKE_SCRIPT && cp $MAKEFILE $MAKE_MAKEFILE && cd $MAKE_DIR && $MAKE_CMD && $MAKE_CHECK",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "statusbar": {
                    "color" : "#226dd6"
                }
            }
        },
        {
            "label": "$(arrow-right) Install",
            "type": "shell",
            "command": "$MADE_COPY && $MADE_INSTALL",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "statusbar": {
                    "color" : "#226dd6"
                }
            }
        }
    ]
}
